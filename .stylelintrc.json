{
  "extends": ["stylelint-config-recommended"],
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "apply",
          "reference",
          "plugin"
        ]
      }
    ],
    "scale-unlimited/declaration-strict-value": [
      ["/color$/", "fill", "stroke"],
      {
        "ignoreValues": [
          "currentColor",
          "inherit",
          "transparent",
          "initial",
          "unset"
        ]
      }
    ]
  }
}
