{
  "name": "blog",
  "private": true,
  "type": "module",
  "scripts": {},
  "sideEffects": false,
  "nx": {
    "name": "blog",
    "tags": [
      "scope:blog",
      "type:app"
    ],
    "targets": {
      "preview": {
        "command": "vite preview --port 4300",
        "options": {
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          "build"
        ]
      },
      "deploy": {
        "command": "wrangler deploy",
        "options": {
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          "build"
        ]
      },
      "maintenance": {
        "command": "wrangler kv key put maintenance off --binding MAINTENANCE_KV --remote",
        "options": {
          "cwd": "{projectRoot}"
        },
        "configurations": {
          "on": {
            "command": "wrangler kv key put maintenance on --binding MAINTENANCE_KV --remote"
          },
          "off": {}
        },
        "defaultConfiguration": "off",
        "cache": false
      },
      "assess": {
        "executor": "nx:run-commands",
        "cache": false,
        "dependsOn": [
          "build"
        ],
        "options": {
          "cwd": "{workspaceRoot}",
          "command": "node tools/assess.mjs"
        }
      }
    }
  },
  "dependencies": {
    "@dev-blog/icons": "workspace:*",
    "@dev-blog/theme": "workspace:*",
    "@dev-blog/ui": "workspace:*",
    "isbot": "^4.4.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@react-router/dev": "^8.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "wrangler": "^4.107.0"
  },
  "version": "0.8.0"
}
