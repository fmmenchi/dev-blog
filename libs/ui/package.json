{
  "name": "@dev-blog/ui",
  "version": "0.8.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@dev-blog/icons": "workspace:*",
    "@dev-blog/theme": "workspace:*",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "react": "^19.0.0",
    "react-router": "^8.1.0"
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:ui"
    ],
    "targets": {
      "lint-css": {
        "command": "stylelint \"src/**/*.css\"",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.css",
          "{workspaceRoot}/.stylelintrc.json"
        ]
      }
    }
  },
  "sideEffects": [
    "*.css"
  ]
}
