{
  "name": "@dev-blog/ui",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@dev-blog/theme": "workspace:*",
    "react": "^19.0.0",
    "react-router": "^8.1.0"
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:ui"
    ],
    "targets": {
      "lint-css": {
        "command": "stylelint \"src/**/*.css\"",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.css",
          "{workspaceRoot}/.stylelintrc.json"
        ]
      }
    }
  }
}
