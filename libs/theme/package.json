{
  "name": "@dev-blog/theme",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./styles/*": "./src/styles/*"
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:theme"
    ],
    "targets": {
      "lint-css": {
        "command": "stylelint \"src/**/*.css\"",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.css",
          "{workspaceRoot}/.stylelintrc.json"
        ]
      }
    }
  },
  "dependencies": {}
}
