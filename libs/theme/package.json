{
  "name": "@dev-blog/theme",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./styles/*": "./src/styles/*"
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:theme"
    ],
    "targets": {
      "lint-css": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "stylelint \"src/**/*.css\"",
            "node ../../tools/check-tokens.mjs"
          ],
          "cwd": "{projectRoot}",
          "parallel": false
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.css",
          "{workspaceRoot}/.stylelintrc.json",
          "{workspaceRoot}/tools/check-tokens.mjs",
          "{workspaceRoot}/libs/ui/src/**/*",
          "{workspaceRoot}/apps/blog/app/**/*"
        ]
      }
    }
  },
  "dependencies": {}
}
