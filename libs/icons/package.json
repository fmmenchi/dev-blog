{
  "name": "@dev-blog/icons",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:icons"
    ],
    "targets": {
      "generate": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/svg/**/*.svg",
          "{projectRoot}/.svgrrc.cjs",
          "{workspaceRoot}/tools/svgr-index.cjs"
        ],
        "outputs": [
          "{projectRoot}/src"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "svgr --out-dir src --index-template ../../tools/svgr-index.cjs svg"
        }
      },
      "typecheck": {
        "dependsOn": [
          "generate"
        ]
      },
      "build": {
        "dependsOn": [
          "generate"
        ]
      },
      "lint": {
        "executor": "nx:run-commands",
        "cache": true,
        "dependsOn": [
          "generate"
        ],
        "inputs": [
          "{projectRoot}/src/**/*.tsx",
          "{workspaceRoot}/tools/check-icons.mjs"
        ],
        "options": {
          "cwd": "{workspaceRoot}",
          "command": "node tools/check-icons.mjs"
        }
      }
    }
  }
}
