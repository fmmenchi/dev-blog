{
  "name": "@dev-blog/security",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@dev-blog/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "plugins/security/dist",
          "main": "plugins/security/src/index.ts",
          "tsConfig": "plugins/security/tsconfig.lib.json",
          "rootDir": "plugins/security/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./plugins/security/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./plugins/security/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      },
      "secrets": {
        "executor": "@dev-blog/security:trivy",
        "cache": true,
        "inputs": [
          "{workspaceRoot}/**/*",
          "!{workspaceRoot}/node_modules/**/*"
        ],
        "options": {
          "scanners": [
            "secret"
          ],
          "project": null
        },
        "configurations": {
          "ci": {
            "runner": "docker"
          }
        }
      },
      "scan": {
        "executor": "nx:noop",
        "dependsOn": [
          {
            "projects": [
              "blog"
            ],
            "target": "vuln"
          },
          "secrets"
        ],
        "configurations": {
          "ci": {}
        }
      },
      "notify": {
        "executor": "@dev-blog/security:notify",
        "cache": false,
        "options": {
          "message": ":rotating_light: *The weekly security scan went red.*\n\nNothing was committed. A CVE was published against a dependency that was already there \u2014 which is the one thing only this scan can catch."
        },
        "configurations": {
          "test": {
            "message": ":white_check_mark: *Test message.* The security scan can reach this channel \u2014 so the day it goes red, this is where you will hear about it."
          }
        }
      }
    },
    "tags": [
      "scope:shared",
      "type:tooling"
    ]
  },
  "dependencies": {
    "@nx/devkit": "23.0.1",
    "tslib": "^2.3.0",
    "@dev-blog/notify": "workspace:*"
  },
  "executors": "./executors.json",
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "executors.json"
  ]
}
